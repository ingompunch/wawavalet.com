rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'drive5746@gmail.com'
      );
    }

    function isValidReservation(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.carNumber is string && data.carNumber.size() <= 20 &&
             data.terminal in ['T1', 'T2'] &&
             data.entryDate is string &&
             data.exitDate is string &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    // Site Settings: Public read, Admin write
    match /settings/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reservations: Public create, Admin read/write
    match /reservations/{reservationId} {
      allow create: if isValidReservation(request.resource.data) && 
                      request.resource.data.status == 'pending';
      allow read, list, update, delete: if isAdmin();
    }

    // Admins: Only admins can manage admins
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
