{
  "entities": {
    "reservation": {
      "title": "Reservation",
      "description": "A parking reservation request from a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "carNumber": { "type": "string" },
        "carModel": { "type": "string" },
        "entryDate": { "type": "string" },
        "entryTime": { "type": "string" },
        "entryTerminal": { "type": "string" },
        "entryAirline": { "type": "string" },
        "entryFlight": { "type": "string" },
        "exitDate": { "type": "string" },
        "exitTime": { "type": "string" },
        "exitTerminal": { "type": "string" },
        "exitAirline": { "type": "string" },
        "exitFlight": { "type": "string" },
        "destination": { "type": "string" },
        "notes": { "type": "string" },
        "password": { "type": "string" },
        "parkingType": { "type": "string", "enum": ["indoor", "outdoor"] },
        "totalPrice": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "carNumber", "carModel", "entryDate", "entryTime", "entryTerminal", "exitDate", "exitTime", "exitTerminal", "destination", "password", "parkingType", "status"]
    },
    "admin": {
      "title": "Admin",
      "description": "User with administrative privileges.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "reservations/{reservationId}": {
      "schema": "reservation",
      "description": "Parking reservations storage"
    },
    "admins/{adminId}": {
      "schema": "admin",
      "description": "Authenticated admin users"
    }
  }
}
